# Waynode AI — Environment Configuration

# ── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Used to sign session cookies — generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-string

# Used to encrypt stored secrets — generate with: openssl rand -hex 32
ENCRYPTION_KEY=change-me-to-a-different-random-string

# Base URL of your deployment (used for OAuth callbacks)
APP_URL=http://localhost:3000

# ── GitHub OAuth ────────────────────────────────────────
# Create at: GitHub → Settings → Developer settings → OAuth Apps → New
# Callback URL: ${APP_URL}/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── GitLab OAuth ────────────────────────────────────────
# Create at: GitLab → User Settings → Applications
# Redirect URI: ${APP_URL}/auth/gitlab/callback
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_BASE_URL=https://gitlab.com

# ── Pi ──────────────────────────────────────────────────
# Default model when none is specified per-session
PI_DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514
# Default provider
PI_DEFAULT_PROVIDER=anthropic

# ── Fornace LLM gateway (fornace-hosted deployments) ────
# Supplied at container RUNTIME (not baked into the Docker image — see
# lib/pi-config.mjs). Leave unset for self-host installs using their own
# PI_DEFAULT_PROVIDER/model instead.
# LLM_BASE_URL=fornace-llm:4000
# LLM_API_KEY=

# ── Billing (hosted waynode.fornace.net ONLY — leave unset for self-host) ──
# Self-hosters: do not set these. Billing is fully optional; leaving all of
# this blank hides the Billing UI entirely and every billing route 404s
# cleanly. See docs/PRICING.md for the tier definitions these price IDs map to.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_TEAM=price_...
