# Waynode self-host environment
# Recommended: run ./scripts/self-host.sh setup instead of editing this by hand.

# Server ---------------------------------------------------------------------
PORT=3000
NODE_ENV=production
# Compose binds to loopback by default. Use 0.0.0.0 only behind a firewall or
# when a reverse proxy runs on another host.
WAYNODE_BIND_ADDRESS=127.0.0.1
APP_URL=http://localhost:3000

# Generate two different values with: openssl rand -hex 32
SESSION_SECRET=
ENCRYPTION_KEY=

# Login ----------------------------------------------------------------------
# Configure at least one complete OAuth pair. Callback URLs are exact:
#   GitHub: ${APP_URL}/auth/github/callback
#   GitLab: ${APP_URL}/auth/gitlab/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_BASE_URL=https://gitlab.com

# Coding model ---------------------------------------------------------------
# PI_DEFAULT_PROVIDER and PI_DEFAULT_MODEL must describe the same pi model.
# On first self-host boot, Waynode encrypts PI_PROVIDER_API_KEY into its global
# secret vault under the matching provider key and removes it from the runtime
# environment before an agent can start. It never overwrites a rotated secret.
PI_DEFAULT_PROVIDER=
PI_DEFAULT_MODEL=
PI_PROVIDER_API_KEY=

# Waynode Cloud only. Ordinary self-host installs should leave these blank.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
# Hosted operator only: a separately provisioned model/rate-limited virtual
# key for one-shot sandbox chat. This must never be the gateway admin key.
WAYNODE_SANDBOX_LLM_KEY=
# Mantice gateway ADMIN token (server-side only; mints/disables per-org LLM
# keys via /admin/tokens). Optional: without it, hosted chat uses the shared
# WAYNODE_SANDBOX_LLM_KEY for every org.
LLM_ADMIN_TOKEN=

# Self-host safety ------------------------------------------------------------
# Do not set WAYNODE_DEPLOYMENT=hosted or any Stripe variables. Billing and
# hosted usage limits remain disabled when this value is self-hosted.
WAYNODE_DEPLOYMENT=self-hosted
