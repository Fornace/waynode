{
  "name": "waynode",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm run dev:server\" \"npm run dev:frontend\"",
    "dev:server": "node --watch server.js",
    "dev:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "start": "cross-env NODE_ENV=production node server.js",
    "typecheck": "cd frontend && npx tsc --noEmit",
    "test:auth": "node e2e/test-native-auth.mjs",
    "test:account-deletion": "node e2e/test-account-deletion.mjs",
    "test:billing": "node e2e/test-billing.mjs",
    "test:app-store": "node e2e/test-app-store.mjs",
    "test": "npm run test:billing && npm run test:app-store && npm run test:auth && npm run test:account-deletion && npm run typecheck"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.11",
    "ai": "^7.0.20",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "express-session": "1.19.0",
    "helmet": "8.2.0",
    "microsandbox": "^0.6.6",
    "multer": "^2.2.0",
    "node-pty": "1.1.0",
    "passport": "0.7.0",
    "passport-github2": "0.1.12",
    "passport-gitlab2": "5.0.0",
    "stripe": "^22.3.1",
    "uuid": "14.0.1",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "concurrently": "10.0.3",
    "cross-env": "10.1.0"
  }
}
